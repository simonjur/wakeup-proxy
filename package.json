{
  "name": "immich-wake-proxy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Reverse proxy that wakes an Immich server via Home Assistant and shows a waiting screen until it's up.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.ts",
    "dev": "node --watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "http-proxy-3": "^1.20.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^70.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1"
  }
}
