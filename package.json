{
  "name": "immich-wake-proxy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Reverse proxy that wakes an Immich server via Home Assistant and shows a waiting screen until it's up.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node src/server.ts",
    "dev": "node --watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tests:unit": "vitest run --config vitest.unit.config.ts",
    "tests:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "http-proxy-3": "^1.20.5",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unicorn": "^70.0.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
