# ---- Proxy ----
HOST=0.0.0.0
PORT=3000

# ---- Logging ----
# error | warn | info | debug (default: info). Use "debug" for detailed
# health-probe and wake tracing when troubleshooting.
LOG_LEVEL=info

# ---- Upstream (the service to wake & proxy to) ----
UPSTREAM_URL=http://192.168.1.10:2283
# Path probed to decide if the upstream is up (any non-5xx response = up).
#   Immich:       /api/server/ping
#   generic app:  /
UPSTREAM_HEALTH_PATH=/api/server/ping

# Optional logo shown on the waiting page. Two forms:
#   - "sh-<name>"  a free selfh.st icon (https://selfh.st/icons/), e.g.
#                  UPSTREAM_ICON=sh-immich  ->  the immich.svg from the CDN.
#   - any full URL to an image (svg/png/…), used as-is.
# UPSTREAM_ICON=sh-immich

# ---- Waiting page copy ----
WAITING_TITLE=Waking the server
WAITING_MESSAGE=This usually takes a moment. You'll be redirected automatically once it's ready.

# ---- Timings (ms) ----
HEALTH_CACHE_MS=3000       # cache the up/down result this long
HEALTH_TIMEOUT_MS=2000     # per health-check timeout
WAKE_COOLDOWN_MS=60000     # min gap between wake calls (also re-sends WoL after this)
WAKE_TIMEOUT_MS=5000       # timeout for the HA call
POLL_INTERVAL_MS=3000      # how often the waiting page re-checks

# ---- Metrics ----
# Prometheus metrics endpoint (default Node.js metrics + upstream up/down,
# request counts by method, response counts by status code). Change the path
# here, or set METRICS_URL= (empty) to disable the endpoint entirely.
METRICS_URL=/metrics

# ---- Wake services ----
# Any number can be enabled at once; every configured service is fired on wake.

# ---- Home Assistant wake ----
# Option A: webhook (no token). If set, this is used and the service vars below are ignored.
# HA_WAKE_WEBHOOK_URL=http://homeassistant.local:8123/api/webhook/wake_immich_xxxxx

# Option B: service call (long-lived access token).
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-access-token

# Example 1 — run a script:
HA_WAKE_SERVICE=script.turn_on
HA_WAKE_ENTITY_ID=script.wake_immich_server

# Example 2 — direct Wake-on-LAN (comment out the two lines above, uncomment below):
# HA_WAKE_SERVICE=wake_on_lan.send_magic_packet
# HA_WAKE_DATA={"mac":"AA:BB:CC:DD:EE:FF"}

# Extra/override service data as JSON (merged after entity_id):
# HA_WAKE_DATA={"variables":{"reason":"proxy"}}

# ---- Shell command wake ----
# Runs the given command via /bin/sh -c on wake (subject to WAKE_TIMEOUT_MS).
# WAKE_SHELL_COMMAND=etherwake AA:BB:CC:DD:EE:FF
